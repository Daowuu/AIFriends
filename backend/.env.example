# Django
DJANGO_SECRET_KEY="replace-me-in-production"
DJANGO_DEBUG="true"
DJANGO_ALLOWED_HOSTS="127.0.0.1,localhost,testserver"
DJANGO_CORS_ALLOWED_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"
DJANGO_CSRF_TRUSTED_ORIGINS=""
DJANGO_MEDIA_URL="/media/"

# Runtime config stored as JSON in .env.
# - active.chat_provider controls which chat provider is live.
# - api_keys stores one key per provider.
# - chat stores one config per provider.
# - voice stores the single ASR/TTS runtime.
AI_RUNTIME_CONFIG_JSON='{
  "version": 4,
  "active": {
    "chat_provider": "openai"
  },
  "api_keys": {
    "openai": "",
    "minimax": "",
    "aliyun_voice": ""
  },
  "chat": {
    "openai": {
      "api_base": "https://api.openai.com/v1",
      "model_name": "gpt-5.4",
      "updated_at": ""
    },
    "minimax": {
      "api_base": "https://api.minimaxi.com/v1",
      "model_name": "MiniMax-M2.7-highspeed",
      "updated_at": ""
    }
  },
  "voice": {
    "provider": "aliyun",
    "api_base": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "asr_model_name": "qwen3-asr-flash",
    "tts_model_name": "cosyvoice-v3.5-plus",
    "updated_at": ""
  }
}'

# Optional quota when requests use the synced runtime config
DEMO_TEXT_CHAT_LIMIT="20"
DEMO_VOICE_CHAT_LIMIT="5"
